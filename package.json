{
	"name": "limn",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "devkit",
		"dev:open": "devkit --open",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devkit": {
		"apps": [
			{ "name": "limn", "command": "vite dev", "port": 5173, "color": "magenta", "open": true }
		]
	},
	"devDependencies": {
		"@elumixor/devkit": "^0.2.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	}
}
